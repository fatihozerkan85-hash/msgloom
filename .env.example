# Database
POSTGRES_URL=your_neon_postgres_connection_string

# Authentication (REQUIRED - use strong random values)
JWT_SECRET=generate_a_strong_random_secret_here
ADMIN_PASSWORD=generate_a_strong_admin_password_here

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=MsgLoom <noreply@msgloom.com.tr>

# Meta / Facebook
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# WhatsApp
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token

# Telegram
TELEGRAM_WEBHOOK_SECRET=generate_a_strong_random_secret_here

# Token Encryption (for encrypting stored OAuth tokens)
TOKEN_ENCRYPTION_KEY=generate_a_strong_random_key_here

# Database Setup (REQUIRED - separate from JWT_SECRET)
SETUP_DB_SECRET=generate_a_unique_setup_secret_here

# iyzico Payment
IYZICO_API_KEY=your_iyzico_api_key
IYZICO_SECRET_KEY=your_iyzico_secret_key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# App URL
NEXT_PUBLIC_APP_URL=https://msgloom.com.tr
